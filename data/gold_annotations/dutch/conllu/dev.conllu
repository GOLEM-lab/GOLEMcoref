# sent_id = 19-763
# text = Dat klinkt absurd, maar zou jij ook niet opkijken naar je broer als hij:
# text = •\tVernoemd is naar een overheerlijke, tropische vrucht die van een andere planeet komt
# text = •\tGouden hoorns heeft
# text = •\tDe heldenmedaille van het Fenaris-rijk heeft
# text = •\tEen epische kamer in Dennenmarks heeft
# text = •\tDe aarden joker heeft gewonnen (goede prijs van de natuurqiyos voor entertainment)
